# ── Required ──

# App password (CHANGE THIS for production!)
APP_PASSWORD=changeme

# Server port
PORT=3001

# Data directory (where SQLite DB and audio files are stored)
DATA_DIR=./data

# Node environment (development | production)
NODE_ENV=development

# ── TTS API Keys (set here or via Settings page in the app) ──

# ElevenLabs (primary TTS, SFX, music generation)
ELEVENLABS_API_KEY=

# OpenAI TTS
OPENAI_API_KEY=

# Google Cloud TTS
GOOGLE_TTS_API_KEY=

# Amazon Polly
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Deepgram Aura TTS
DEEPGRAM_API_KEY=

# ── LLM API Keys (at least one required for AI auto-assign) ──

MISTRAL_API_KEY=
GEMINI_API_KEY=

# ── Optional ──

# CORS: comma-separated list of allowed origins (default: allow all)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
